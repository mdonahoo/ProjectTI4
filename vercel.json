{
  "functions": {
    "api/chat.js": {
      "includeFiles": "data/**",
      "maxDuration": 30
    },
    "api/speak.js": {
      "maxDuration": 30
    },
    "api/clone-voice.js": {
      "maxDuration": 60
    },
    "api/podcast-script.js": {
      "maxDuration": 30
    },
    "api/music.js": {
      "maxDuration": 120
    },
    "api/sfx.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
